# ──────────────────────────────────────────────
#  Kundapura Edits Studio — Environment Config
# ──────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/kundapura_edits?retryWrites=true&w=majority

# JWT — CHANGE THIS to a long random string before deploying!
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# Admin credentials — CHANGE THESE!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_password_here

# Frontend URL (used for CORS in production)
FRONTEND_URL=https://your-app.onrender.com

# Cloudinary — required for video uploads
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
